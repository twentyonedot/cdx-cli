{
  "name": "@twentyonedot/cdx-cli",
  "version": "0.1.0-beta.1",
  "description": "Automatic account switching for Codex using authorized ChatGPT/Codex login snapshots.",
  "type": "module",
  "bin": {
    "cdx": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md",
    "docs"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && node scripts/chmod-bin.mjs",
    "prepare": "npm run build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint \"src/**/*.ts\"",
    "test": "npm run build && node --test tests/*.test.mjs",
    "scan:private": "node scripts/scan-private.mjs",
    "quality": "npm run lint && npm run typecheck && npm test && npm run scan:private && npm pack --dry-run"
  },
  "keywords": [
    "codex",
    "cli",
    "autoswitch",
    "chatgpt"
  ],
  "author": "twentyonedot",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/twentyonedot/cdx-cli.git"
  },
  "bugs": {
    "url": "https://github.com/twentyonedot/cdx-cli/issues"
  },
  "homepage": "https://github.com/twentyonedot/cdx-cli#readme",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "commander": "^12.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.15.0",
    "@types/node": "^22.9.0",
    "eslint": "^9.15.0",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.14.0"
  }
}
